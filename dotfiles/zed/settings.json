{
  "hover_popover_enabled": true,
  "auto_signature_help": false,
  "lsp_document_colors": "background",
  "auto_install_extensions": {
    "lua": true,
    "nix": true
  },
  "base_keymap": "VSCode",
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "buffer_font_size": 14,
  "completions": {
    "lsp_insert_mode": "replace"
  },
  "helix_mode": true,
  "inlay_hints": {
    "show_background": true,
    "enabled": true
  },
  "minimap": {
    "display_in": "active_editor",
    "show": "auto",
    "thumb": "always"
  },
  "prettier": {
    "allowed": true
  },
  "session": {
    "trust_all_worktrees": true
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "theme": "Autumn Dark",
  "ui_font_family": "JetBrainsMono Nerd Font",
  "ui_font_size": 16,
  "vim_mode": false,
  "which_key": {
    "delay_ms": 0,
    "enabled": true
  },
  "diagnostics": {
    "inline": {
      "enabled": true
    }
  }
}